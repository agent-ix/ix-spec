{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "types": ["node", "vitest/globals"],
    "rootDir": "src"
  },
  "include": ["src"],
  "exclude": ["tests", "dist", "node_modules"]
}
